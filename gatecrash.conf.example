# Gatecrash configuration
# Copy this file to gatecrash.conf and fill in your values.
# Do not commit gatecrash.conf — it contains your private network details.

# LAN interface (the bridged adapter on your LAN)
LAN_IF="eth0"

# WireGuard interface name (must match the .conf filename in /etc/wireguard/)
VPN_IF="wg0"

# Your LAN gateway IP (your router).
# Leave blank to auto-detect from the default route on every boot — recommended,
# so the appliance works when moved between networks.
GATEWAY_IP=""

# Space-separated list of target device IPs to route through VPN
# Example: TARGET_IPS="192.168.1.90 192.168.1.183"
TARGET_IPS="192.168.1.90"

# DNS resolver for target devices. Gatecrash DNAT's each target's DNS queries
# to this address (port 53) so they resolve through the VPN tunnel rather than
# leaking to your ISP. Leave blank to use the default, 1.1.1.1 (Cloudflare).
# Set it to your VPN provider's resolver, a privacy DNS, etc. if you prefer.
DNS_SERVER=""

# Policy routing table name and fwmark (no need to change these)
ROUTE_TABLE="vpntarget"
FWMARK="0x1"
