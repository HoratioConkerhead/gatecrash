# Sudoers drop-in for the Gatecrash web UI (runs as user "gatecrash").
# Only the specific commands the web UI needs are permitted — no blanket root.

# Service management
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl start gatecrash
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl stop gatecrash
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl restart gatecrash
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl enable gatecrash
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl disable gatecrash
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl status gatecrash *
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl is-active gatecrash
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl is-enabled gatecrash

# WireGuard service
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl enable wg-quick@wg0
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl disable wg-quick@wg0
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl is-active wg-quick@wg0
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl is-enabled wg-quick@wg0
gatecrash ALL=(root) NOPASSWD: /usr/bin/wg-quick up wg0
gatecrash ALL=(root) NOPASSWD: /usr/bin/wg-quick down wg0
gatecrash ALL=(root) NOPASSWD: /usr/bin/wg show wg0

# Network inspection
gatecrash ALL=(root) NOPASSWD: /usr/sbin/ip *
gatecrash ALL=(root) NOPASSWD: /usr/sbin/iptables *
gatecrash ALL=(root) NOPASSWD: /usr/bin/nmap *
gatecrash ALL=(root) NOPASSWD: /usr/bin/tcpdump *
gatecrash ALL=(root) NOPASSWD: /usr/sbin/conntrack *
gatecrash ALL=(root) NOPASSWD: /usr/bin/ss *
gatecrash ALL=(root) NOPASSWD: /usr/bin/curl --interface wg0 *

# System power
gatecrash ALL=(root) NOPASSWD: /usr/sbin/shutdown *
gatecrash ALL=(root) NOPASSWD: /usr/bin/systemctl reboot

# Diagnostics
gatecrash ALL=(root) NOPASSWD: /usr/bin/pgrep *
gatecrash ALL=(root) NOPASSWD: /usr/bin/dig *
gatecrash ALL=(root) NOPASSWD: /usr/bin/hostname

# Upgrades — the web UI spawns a root upgrade script
gatecrash ALL=(root) NOPASSWD: /usr/bin/bash /tmp/gatecrash-upgrade-*.sh
gatecrash ALL=(root) NOPASSWD: /usr/bin/git *
